<div class="container d-flex flex-column align-items-center justify-content-center min-vh-100">
  <div class="w-100" style="max-width: 400px">
    <div class="text-center mb-4">
      <h1 class="fs-3 fw-bold">Bem vinda!</h1>
      <p class="text-muted small">
        Quantas vezes você deixou de ir a um cinema, show ou exposição por não ter companhia?
        O Connecta é para mulheres que buscam companhia nesses momentos, com segurança e confiança.
      </p>
    </div>

    <%= simple_form_for @profile, url: profile_path do |f| %>
      <%= f.input :name,
                  label: false,
                  placeholder: "Nome",
                  input_html: { class: "form-control mb-2" } %>
      <%= f.input :username,
                  label: false,
                  placeholder: "Nome de usuária (@username)",
                  input_html: { class: "form-control mb-2" } %>

      <%# Cidade %>
      <div class="mb-2">
        <%= f.input :location,
                    label: false,
                    as: :select,
                    collection: Profile::CITIES,
                    prompt: "Selecione sua cidade",
                    input_html: { class: "form-select" } %>

      </div>

      <%# Interesses %>
      <div class="mb-2">
        <select name="profile[interests][]" class="form-select mb-2">
          <option value="">Primeiro interesse</option>
          <% Profile::INTERESTS.each do |interest| %>
            <option value="<%= interest %>"><%= interest %></option>
          <% end %>
        </select>
        <select name="profile[interests][]" class="form-select">
          <option value="">Segundo interesse (opcional)</option>
          <% Profile::INTERESTS.each do |interest| %>
            <option value="<%= interest %>"><%= interest %></option>
          <% end %>
        </select>
      </div>

      <%= f.input :description,
                  as: :text,
                  label: false,
                  placeholder: "Fale um pouco sobre você",
                  input_html: { class: "form-control mb-2", rows: 3 } %>
      <%= f.input :picture,
                  as: :file,
                  label: false,
                  placeholder: "Acrescente uma foto",
                  input_html: { class: "form-control mb-3" } %>

      <%= f.button :submit, "Criar perfil", class: "btn btn-outline-dark w-100" %>
    <% end %>
  </div>
</div>
