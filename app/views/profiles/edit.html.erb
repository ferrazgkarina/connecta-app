<div class="container d-flex flex-column align-items-center justify-content-center min-vh-100">
  <div class="w-100" style="max-width: 400px">
    <div class="text-center mb-4">
      <p class="text-muted small">Mudou de localização ou descobriu novos interesses?</p>
      <h1 class="fs-4 fw-bold">Atualize o seu perfil</h1>
    </div>

    <%= simple_form_for @profile, url: profile_path, method: :patch do |f| %>
      <%= f.input :name,
                  label: false,
                  placeholder: "Nome",
                  input_html: { class: "form-control mb-2" } %>
      <%= f.input :username,
                  label: false,
                  placeholder: "Nome de usuária",
                  input_html: { class: "form-control mb-2" } %>
      <%= f.input :location,
                  label: false,
                  as: :select,
                  collection: Profile::CITIES,
                  prompt: "Selecione sua cidade",
                  input_html: { class: "form-select mb-2" } %>
      <p class="text-muted mb-2" style="font-size: 0.75rem">
        Sua cidade ainda não está disponível? Quem sabe no futuro!
      </p>

      <select name="profile[interests][]" class="form-select mb-2">
        <option value="">Primeiro interesse</option>
        <% Profile::INTERESTS.each do |interest| %>
          <option value="<%= interest %>" <%= "selected" if @profile.interests&.first == interest %>><%= interest %></option>
        <% end %>
      </select>
      <select name="profile[interests][]" class="form-select mb-2">
        <option value="">Segundo interesse (opcional)</option>
        <% Profile::INTERESTS.each do |interest| %>
          <option value="<%= interest %>" <%= "selected" if @profile.interests&.second == interest %>><%= interest %></option>
        <% end %>
      </select>
      <%= f.input :description,
                  as: :text,
                  label: false,
                  placeholder: "Fale um pouco sobre você",
                  input_html: { class: "form-control mb-2", rows: 3 } %>
      <%= f.input :picture,
                  as: :file,
                  label: false,
                  placeholder: "Acrescente uma foto",
                  input_html: { class: "form-control mb-3" } %>

      <%= f.button :submit, "Editar perfil", class: "btn btn-dark w-100" %>
    <% end %>

    <hr class="my-4">

    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-danger w-100" do %>
      <i class="fa-solid fa-right-from-bracket me-1"></i> Sair da conta
    <% end %>
  </div>
</div>
