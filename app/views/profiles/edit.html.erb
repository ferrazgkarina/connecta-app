<div class="container d-flex flex-column align-items-center justify-content-center min-vh-100">
  <div class="w-100" style="max-width: 400px">
    <div class="text-center mb-4">
      <p class="text-muted small">Mudou de localização ou descobriu novos interesses?</p>
      <h1 class="fs-4 fw-bold">Atualize o seu perfil</h1>
    </div>

    <%= simple_form_for @profile, url: profile_path, method: :patch do |f| %>
      <%= f.input :name,
                  label: false,
                  placeholder: "Nome",
                  input_html: { class: "form-control mb-2" } %>
      <%= f.input :username,
                  label: false,
                  placeholder: "Nome de usuária",
                  input_html: { class: "form-control mb-2" } %>
      <%= f.input :location,
                  label: false,
                  placeholder: "Cidade",
                  input_html: { class: "form-control mb-2" } %>
      <%= f.input :interests,
                  label: false,
                  placeholder: "Interesses",
                  input_html: { class: "form-control mb-2" } %>
      <%= f.input :description,
                  as: :text,
                  label: false,
                  placeholder: "Fale um pouco sobre você",
                  input_html: { class: "form-control mb-2", rows: 3 } %>
      <%= f.input :picture,
                  as: :file,
                  label: false,
                  placeholder: "Acrescente uma foto",
                  input_html: { class: "form-control mb-3" } %>

      <%= f.button :submit, "Editar perfil", class: "btn btn-dark w-100" %>
    <% end %>
  </div>
</div>
