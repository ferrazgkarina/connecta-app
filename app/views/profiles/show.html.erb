<div class="container py-4" style="max-width: 480px">

  <%# Header: saudação + perfil %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fs-4 fw-bold mb-0">Olá, <%= @profile.name || @profile.username %>!</h1>
      <%= link_to edit_profile_path, class: "small text-decoration-underline text-muted" do %>
        <i class="fa-solid fa-location-dot"></i> <%= @profile.location %>
        <i class="fa-solid fa-pen fa-xs ms-1"></i>
      <% end %>
    </div>
    <div class="rounded-circle bg-secondary" style="width: 56px; height: 56px; overflow: hidden;">
      <% if @profile.picture.present? %>
        <img src="<%= @profile.picture %>" alt="Foto de perfil" class="w-100 h-100" style="object-fit: cover;">
      <% end %>
    </div>
  </div>

  <%# Notificações de compartilhamento %>
  <% if @unread_shares.any? %>
    <div class="mb-4">
      <% @unread_shares.each do |share| %>
        <%= link_to mark_read_share_path(share), data: { turbo_method: :patch }, class: "text-decoration-none text-dark" do %>
          <div class="d-flex align-items-center gap-3 border border-dark rounded-3 p-2 mb-2">
            <i class="fa-solid fa-share-nodes text-dark fs-5"></i>
            <div>
              <p class="small fw-bold mb-0">
                @<%= share.sharer.profile&.username %> compartilhou um encontro com você!
              </p>
              <p class="text-muted mb-0" style="font-size: 0.75rem"><%= share.event.title %></p>
            </div>
            <i class="fa-solid fa-chevron-right text-muted ms-auto"></i>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# Encontros disponíveis %>
  <h2 class="fs-6 fw-bold mb-2">Encontros baseados nos seus interesses:</h2>

  <div class="d-flex gap-3 overflow-auto pb-2 mb-3">
    <% if @nearby_events.any? %>
      <% @nearby_events.each do |event| %>
        <%= link_to event_path(event), class: "text-decoration-none text-dark flex-shrink-0", style: "width: 150px" do %>
          <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-2">
              <div class="bg-dark text-white rounded-2 text-center p-1 mb-2" style="font-size: 0.7rem; width: 36px">
                <div class="fw-bold" style="font-size: 0.9rem"><%= event.date.strftime("%d") %></div>
                <div><%= I18n.l(event.date, format: "%b").upcase %></div>
              </div>
              <p class="fw-bold mb-0 small"><%= event.title %></p>
              <p class="text-muted mb-0" style="font-size: 0.7rem"><%= event.user.profile&.username %></p>
              <p class="text-muted mb-1" style="font-size: 0.7rem"><%= event.address %></p>
              <p class="small mb-0"><%= pluralize(event.attendances.count, "presença", "presenças") %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-muted small">Nenhum encontro nos seus interesses por aqui ainda.</p>
    <% end %>
  </div>

  <%= link_to "Veja todos os encontros em #{@profile.location}", events_path(city: @profile.location), class: "btn btn-outline-dark w-100 mb-4" %>

  <%# CTA criar encontro %>
  <p class="text-center small mb-2">Não achou o que procura?</p>
  <%= link_to "Crie o seu encontro", new_event_path, class: "btn btn-outline-dark w-100 mb-4" %>

  <%# Meus encontros %>
  <h2 class="fs-6 fw-bold mb-2">Meus encontros:</h2>

  <div class="d-flex gap-3 overflow-auto pb-2 mb-3">
    <% if @my_events.any? %>
      <% @my_events.each do |event| %>
        <%= link_to event_path(event), class: "text-decoration-none text-dark flex-shrink-0", style: "width: 150px" do %>
          <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-2">
              <div class="bg-dark text-white rounded-2 text-center p-1 mb-2" style="font-size: 0.7rem; width: 36px">
                <div class="fw-bold" style="font-size: 0.9rem"><%= event.date.strftime("%d") %></div>
                <div><%= I18n.l(event.date, format: "%b").upcase %></div>
              </div>
              <p class="fw-bold mb-0 small"><%= event.title %></p>
              <p class="text-muted mb-1" style="font-size: 0.7rem"><%= event.address %></p>
              <p class="small mb-0"><%= pluralize(event.attendances.count, "presença", "presenças") %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-muted small">Você ainda não criou nenhum encontro.</p>
    <% end %>
  </div>

  <%= link_to "Veja todos os seus encontros confirmados", confirmed_events_path, class: "btn btn-outline-dark w-100 mb-5" %>

  <%= render "shared/footer_nav" %>

</div>

<%# Modal de novas confirmações de presença %>
<% if @unseen_attendances.any? %>
  <div class="modal fade" id="attendanceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 rounded-4 p-4">
        <div class="modal-body">
          <p class="text-center" style="font-size: 1.5rem">🎉</p>
          <h5 class="fw-bold mb-1 text-center">Novas confirmações!</h5>
          <p class="text-muted small text-center mb-4">Alguém vai junto com você.</p>

          <% @unseen_attendances.each do |attendance| %>
            <div class="d-flex align-items-center gap-3 mb-3">
              <div class="rounded-circle bg-secondary flex-shrink-0" style="width: 36px; height: 36px;"></div>
              <div class="flex-grow-1">
                <p class="small fw-bold mb-0">
                  @<%= attendance.user.profile&.username || attendance.user.email.split("@").first %>
                  confirmou presença em <em><%= attendance.event.title %></em>
                </p>
                <p class="text-muted mb-0" style="font-size: 0.72rem">Diga oi no chat do encontro!</p>
              </div>
              <%= link_to event_path(attendance.event), class: "btn btn-sm btn-outline-dark flex-shrink-0" do %>
                <i class="fa-solid fa-message"></i>
              <% end %>
            </div>
          <% end %>

          <button class="btn btn-dark w-100 mt-2" data-bs-dismiss="modal">Entendido!</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("turbo:load", function () {
      var modal = new bootstrap.Modal(document.getElementById("attendanceModal"), { backdrop: true });
      modal.show();
      document.getElementById("attendanceModal").addEventListener("hidden.bs.modal", function () {
        fetch("<%= mark_seen_attendances_path %>", {
          method: "POST",
          headers: { "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content }
        });
      });
    });
  </script>
<% end %>

<%# Popup de reviews pendentes %>
<% if @pending_reviews.any? %>
  <div class="modal fade" id="reviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 rounded-4 p-4">
        <div class="modal-body text-center">
          <p style="font-size: 1.5rem">💛</p>
          <h5 class="fw-bold mb-2">Como foram seus encontros?</h5>
          <p class="text-muted small mb-4">
            Sua avaliação é sobre a companhia e a experiência com quem organizou — não sobre o local ou a programação em si.
            Isso ajuda outras mulheres a se sentirem seguras para participar.
          </p>
          <% @pending_reviews.each do |event| %>
            <%= link_to event_path(event), class: "btn btn-dark w-100 mb-2" do %>
              Avaliar: <%= event.title %>
            <% end %>
          <% end %>
          <button class="btn btn-link text-muted small mt-1" data-bs-dismiss="modal">Agora não</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("turbo:load", function () {
      var modal = new bootstrap.Modal(document.getElementById("reviewModal"), { backdrop: true });
      modal.show();
    });
  </script>
<% end %>
