<div class="container py-4 pb-5" style="max-width: 480px">

  <h1 class="fs-4 fw-bold mb-3">Meus encontros confirmados</h1>

  <%# Busca %>
  <input type="text" class="form-control mb-3" placeholder="Busque por título ou data">

  <%# Filtros de categoria %>
  <div class="d-flex gap-2 overflow-auto pb-2 mb-4" style="scrollbar-width: none">
    <span class="badge rounded-pill bg-dark text-nowrap">Todos</span>
    <% Event::CATEGORIES.each do |cat| %>
      <span class="badge rounded-pill bg-light text-dark border text-nowrap"><%= cat %></span>
    <% end %>
  </div>

  <%# Grid de eventos %>
  <% if @events.any? %>
    <div class="row g-3">
      <% @events.each do |event| %>
        <div class="col-6">
          <%= link_to event_path(event), class: "text-decoration-none text-dark" do %>
            <div class="card border-0 shadow-sm rounded-3 h-100">
              <div class="bg-secondary rounded-top-3" style="height: 80px"></div>
              <div class="card-body p-2">
                <div class="bg-dark text-white rounded-2 text-center p-1 mb-2 d-inline-block" style="font-size: 0.65rem; min-width: 36px">
                  <div class="fw-bold" style="font-size: 0.85rem"><%= event.date.strftime("%d") %></div>
                  <div><%= I18n.l(event.date, format: "%b").upcase %></div>
                </div>
                <p class="fw-bold mb-0 small lh-sm"><%= event.title %></p>
                <p class="text-muted mb-0" style="font-size: 0.7rem"><%= event.user.profile&.username %> · <%= event.address %></p>
                <p class="small mb-0 mt-1"><%= pluralize(event.attendances.count, "presença", "presenças") %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted text-center mt-5">Você ainda não confirmou presença em nenhum encontro.</p>
  </div>
<% end %>

<%# Barra de navegação inferior %>
<nav class="fixed-bottom border-top bg-white py-2">
  <div class="container d-flex justify-content-around" style="max-width: 480px">
    <%= link_to profile_path, class: "text-dark" do %>
      <i class="fa-solid fa-user-group fs-5"></i>
    <% end %>
    <%= link_to "#", class: "text-dark" do %>
      <i class="fa-solid fa-message fs-5"></i>
    <% end %>
    <%= link_to events_path, class: "text-dark" do %>
      <i class="fa-solid fa-calendar fs-5"></i>
    <% end %>
    <%= link_to profile_path, class: "text-dark" do %>
      <i class="fa-solid fa-user fs-5"></i>
    <% end %>
    <%= link_to edit_profile_path, class: "text-dark" do %>
      <i class="fa-solid fa-gear fs-5"></i>
    <% end %>
  </div>
</nav>
