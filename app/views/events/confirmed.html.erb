<div class="container py-4 pb-5" style="max-width: 480px">

  <%= link_to profile_path, class: "text-muted small d-inline-block mb-3" do %>
    <i class="fa-solid fa-arrow-left me-1"></i> Voltar
  <% end %>

  <h1 class="fs-4 fw-bold mb-4">Meus encontros confirmados</h1>

  <%# Navegação do mês %>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <%= link_to confirmed_events_path(month: (@current_month - 1.month).to_s), class: "btn btn-outline-secondary btn-sm" do %>
      <i class="fa-solid fa-chevron-left"></i>
    <% end %>
    <span class="fw-bold text-capitalize">
      <%= I18n.l(@current_month, format: "%B %Y") %>
    </span>
    <%= link_to confirmed_events_path(month: (@current_month + 1.month).to_s), class: "btn btn-outline-secondary btn-sm" do %>
      <i class="fa-solid fa-chevron-right"></i>
    <% end %>
  </div>

  <%# Grid do calendário %>
  <div class="border rounded-3 p-3 mb-4">
    <%# Cabeçalho dos dias da semana %>
    <div class="row g-0 text-center mb-1">
      <% %w[Dom Seg Ter Qua Qui Sex Sáb].each do |day| %>
        <div class="col fw-bold text-muted" style="font-size: 0.7rem"><%= day %></div>
      <% end %>
    </div>

    <%# Dias do mês %>
    <% first_day  = @current_month.beginning_of_month %>
    <% last_day   = @current_month.end_of_month %>
    <% start_pad  = first_day.wday %>

    <div class="row g-0 text-center">
      <% start_pad.times do %>
        <div class="col py-1"></div>
      <% end %>

      <% (first_day..last_day).each do |day| %>
        <% events_today = @events_by_date[day] || [] %>
        <% is_today = day == Date.today %>
        <div class="col py-1">
          <% if events_today.any? %>
            <a href="#day-<%= day %>" class="text-decoration-none">
              <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center bg-dark text-white fw-bold"
                   style="width: 30px; height: 30px; font-size: 0.8rem">
                <%= day.day %>
              </div>
            </a>
          <% elsif is_today %>
            <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center border border-dark"
                 style="width: 30px; height: 30px; font-size: 0.8rem">
              <%= day.day %>
            </div>
          <% else %>
            <div class="mx-auto d-flex align-items-center justify-content-center text-muted"
                 style="width: 30px; height: 30px; font-size: 0.8rem">
              <%= day.day %>
            </div>
          <% end %>
        </div>
        <% if day.wday == 6 && day != last_day %>
          </div><div class="row g-0 text-center">
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Lista de eventos do mês %>
  <% month_events = @events.select { |e| e.date.month == @current_month.month && e.date.year == @current_month.year } %>

  <% if month_events.any? %>
    <h2 class="fs-6 fw-bold mb-3">Encontros em <%= I18n.l(@current_month, format: "%B") %>:</h2>
    <% month_events.each do |event| %>
      <div id="day-<%= event.date %>">
        <%= link_to event_path(event), class: "text-decoration-none text-dark" do %>
          <div class="card border-0 shadow-sm rounded-3 mb-2">
            <div class="card-body p-3 d-flex gap-3 align-items-center">
              <div class="bg-dark text-white rounded-2 text-center p-2 flex-shrink-0" style="min-width: 42px">
                <div class="fw-bold" style="font-size: 1rem"><%= event.date.strftime("%d") %></div>
                <div style="font-size: 0.65rem"><%= I18n.l(event.date, format: "%b").upcase %></div>
              </div>
              <div>
                <p class="fw-bold mb-0 small"><%= event.title %></p>
                <p class="text-muted mb-0" style="font-size: 0.75rem">
                  <i class="fa-solid fa-clock me-1"></i><%= event.time.strftime("%H:%M") %>
                  <% if event.address.present? %>
                    · <i class="fa-solid fa-location-dot me-1"></i><%= event.address %>
                  <% end %>
                </p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p class="text-muted text-center mt-3">Nenhum encontro confirmado este mês.</p>
  <% end %>

</div>

<%= render "shared/footer_nav" %>
