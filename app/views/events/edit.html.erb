<div class="container py-4 pb-5" style="max-width: 480px">

  <h1 class="fs-4 fw-bold mb-4">Edite o seu encontro</h1>

  <%= simple_form_for @event do |f| %>
    <div class="mb-3">
      <label class="form-label small fw-bold">Título do encontro:</label>
      <%= f.input :title,
                  label: false,
                  placeholder: "Ex: Cinema para assistir Ainda Estou Aqui!",
                  input_html: { class: "form-control" } %>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-bold">Quando vai ser?</label>
      <div class="d-flex gap-2">
        <%= f.input :date,
                    label: false,
                    as: :string,
                    input_html: { class: "form-control", type: "date", value: @event.date&.strftime("%Y-%m-%d") } %>
        <%= f.input :time,
                    label: false,
                    as: :string,
                    input_html: { class: "form-control", type: "time", value: @event.time&.strftime("%H:%M") } %>
      </div>
      <%= f.input :duration,
                  label: false,
                  placeholder: "Duração (ex: 2 horas)",
                  input_html: { class: "form-control mt-2" } %>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-bold">Onde vai ser?</label>
      <%= f.input :city,
                  label: false,
                  as: :select,
                  collection: Profile::CITIES,
                  prompt: "Selecione a cidade",
                  input_html: { class: "form-select mb-2" } %>
      <%= f.input :address,
                  label: false,
                  placeholder: "Ex: Av. Paulista 1000",
                  input_html: { class: "form-control" } %>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-bold">Para quem tem interesse em:</label>
      <%= f.input :category,
                  label: false,
                  as: :select,
                  collection: Event::CATEGORIES,
                  prompt: "Escolha uma categoria",
                  input_html: { class: "form-select" } %>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-bold">Custos (se houver):</label>
      <%= f.input :costs,
                  label: false,
                  placeholder: "Ex: Ingresso R$30, consumação R$20",
                  input_html: { class: "form-control" } %>
    </div>

    <div class="mb-3">
      <label class="form-label small fw-bold">Prazo de confirmação:</label>
      <%= f.input :confirmation_deadline,
                  label: false,
                  as: :select,
                  collection: Event::CONFIRMATION_DEADLINES,
                  prompt: "Escolha uma opção",
                  input_html: { class: "form-select" } %>
    </div>

    <div class="mb-4">
      <label class="form-label small fw-bold">Descrição:</label>
      <%= f.input :description,
                  label: false,
                  as: :text,
                  placeholder: "Conte mais sobre o que planeja...",
                  input_html: { class: "form-control", rows: 4 } %>
    </div>

    <%= f.button :submit, "Editar encontro", class: "btn btn-outline-dark w-100" %>
  <% end %>

</div>

<%= render "shared/footer_nav" %>
