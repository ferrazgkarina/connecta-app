<div class="container py-4 pb-5" style="max-width: 480px">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <%= link_to profile_path, class: "text-muted small" do %>
      <i class="fa-solid fa-arrow-left me-1"></i> Voltar
    <% end %>
    <button class="btn btn-sm btn-outline-dark" data-bs-toggle="modal" data-bs-target="#shareModal">
      <i class="fa-solid fa-share-nodes me-1"></i> Compartilhar
    </button>
  </div>

  <%# Imagem de capa %>
  <div class="bg-secondary rounded-3 mb-3" style="height: 160px"></div>

  <%# Título e data %>
  <h1 class="fs-4 fw-bold mb-0"><%= @event.title %></h1>
  <p class="text-muted small mb-3">
    <%= @event.date.strftime("%d/%m") %> às <%= @event.time.strftime("%H:%M") %>
    <% if @event.duration.present? %> - Duração <%= @event.duration %><% end %>
  </p>

  <div class="row g-3 mb-3">
    <%# Coluna esquerda: detalhes %>
    <div class="col-7">
      <% if @event.description.present? %>
        <p class="small mb-2"><strong>Descrição:</strong><br><%= @event.description %></p>
      <% end %>
      <% if @event.address.present? %>
        <p class="small mb-2"><strong>Endereço:</strong><br><%= @event.address %></p>
      <% end %>
      <% if @event.costs.present? %>
        <p class="small mb-2"><strong>Custos:</strong><br><%= @event.costs %></p>
      <% end %>
      <% if @event.confirmation_deadline.present? %>
        <p class="small mb-0"><strong>Prazo para confirmação:</strong><br><%= @event.confirmation_deadline %></p>
      <% end %>
    </div>

    <%# Coluna direita: organizadora %>
    <div class="col-5">
      <p class="small fw-bold mb-1">Organizado por:</p>
      <div class="d-flex align-items-center gap-2 mb-1" data-bs-toggle="modal" data-bs-target="#creatorModal" style="cursor: pointer">
        <div class="rounded-circle bg-secondary flex-shrink-0" style="width: 32px; height: 32px;"></div>
        <span class="small fw-bold text-decoration-underline"><%= @creator.profile&.name || @creator.profile&.username %></span>
      </div>

      <%# Média de avaliações da criadora %>
      <% avg = @event.user.average_rating %>
      <% if avg %>
        <p class="mb-2" style="font-size: 0.75rem">
          <% avg.round.times do %>♥<% end %>
          <span class="text-muted"><%= avg %> / 5</span>
        </p>
      <% else %>
        <p class="text-muted mb-2" style="font-size: 0.7rem">Sem avaliações ainda</p>
      <% end %>

      <% if @event.user.profile&.description.present? %>
        <p class="small text-muted fst-italic mb-2" style="font-size: 0.7rem">"<%= @event.user.profile.description %>"</p>
      <% end %>

      <p class="small fw-bold mb-1"><%= @event.attendances.count %> confirmadas:</p>
      <div class="d-flex flex-wrap gap-2">
        <% @event.attendances.includes(:user).limit(5).each do |attendance| %>
          <div class="text-center" style="width: 40px">
            <div class="rounded-circle bg-secondary border mx-auto" style="width: 32px; height: 32px;"></div>
            <p class="mb-0" style="font-size: 0.6rem; word-break: break-all"><%= attendance.user.profile&.username || attendance.user.email.split("@").first %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Chat do encontro %>
  <div class="border rounded-3 p-3 mb-3">
    <p class="small fw-bold mb-2">Chat do encontro</p>
    <div style="min-height: 80px; max-height: 200px; overflow-y: auto;" class="mb-2">
      <p class="text-muted small text-center mt-3">Nenhuma mensagem ainda.</p>
    </div>
    <div class="d-flex gap-2">
      <input type="text" class="form-control form-control-sm" placeholder="Escreva uma mensagem...">
      <button class="btn btn-dark btn-sm">Enviar</button>
    </div>
  </div>

  <%# Botão participar/cancelar ou editar/cancelar para a criadora %>
  <% if @event.user == current_user %>
    <div class="d-flex gap-2 mb-4">
      <%= link_to "Editar encontro", edit_event_path(@event), class: "btn btn-outline-dark w-50" %>
      <% count = @event.attendances.count %>
      <% confirm_msg = count > 0 ? "#{count} #{count == 1 ? 'pessoa confirmou' : 'pessoas confirmaram'} presença. Tem certeza que deseja cancelar este encontro?" : "Tem certeza que deseja cancelar este encontro?" %>
      <%= button_to "Cancelar encontro", event_path(@event), method: :delete,
          class: "btn btn-outline-danger w-50",
          data: { turbo_confirm: confirm_msg } %>
    </div>
  <% elsif @attendance %>
    <%= button_to "Cancelar participação",
        event_attendance_path(@event, @attendance),
        method: :delete,
        class: "btn btn-outline-danger w-100 mb-4" %>
  <% else %>
    <%= button_to "Quero participar",
        event_attendances_path(@event),
        method: :post,
        class: "btn btn-dark w-100 mb-4" %>
  <% end %>

  <%# Form de review — só aparece se o evento terminou e a usuária participou %>
  <% if @can_review %>
    <%= render "shared/review_form", event: @event %>
  <% elsif @user_review %>
    <div class="border rounded-3 p-3 mb-3 text-center">
      <p class="small fw-bold mb-1">Sua avaliação:</p>
      <p class="mb-1" style="font-size: 1.3rem">
        <% @user_review.rating.times do %>♥<% end %>
      </p>
      <% if @user_review.comment.present? %>
        <p class="text-muted small mb-0">"<%= @user_review.comment %>"</p>
      <% end %>
    </div>
  <% end %>

  <%# Reviews do evento %>
  <% if @reviews.any? %>
    <div class="mb-4">
      <p class="small fw-bold mb-2">Avaliações (<%= @reviews.count %>):</p>
      <% @reviews.each do |review| %>
        <div class="border rounded-3 p-2 mb-2">
          <div class="d-flex align-items-center gap-2 mb-1">
            <div class="rounded-circle bg-secondary flex-shrink-0" style="width: 24px; height: 24px;"></div>
            <span class="small fw-bold"><%= review.reviewer.profile&.username || review.reviewer.email.split("@").first %></span>
            <span class="ms-auto" style="font-size: 0.85rem; color: #e74c3c">
              <% review.rating.times do %>♥<% end %>
            </span>
          </div>
          <% if review.comment.present? %>
            <p class="text-muted small mb-0">"<%= review.comment %>"</p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Talvez você também curta %>
  <% if @related_events.any? %>
    <h2 class="fs-6 fw-bold mb-2">Talvez você também curta:</h2>
    <div class="d-flex gap-3 overflow-auto pb-2">
      <% @related_events.each do |event| %>
        <%= link_to event_path(event), class: "text-decoration-none text-dark flex-shrink-0", style: "width: 150px" do %>
          <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-2">
              <div class="bg-dark text-white rounded-2 text-center p-1 mb-2" style="font-size: 0.7rem; width: 36px">
                <div class="fw-bold" style="font-size: 0.9rem"><%= event.date.strftime("%d") %></div>
                <div><%= I18n.l(event.date, format: "%b").upcase %></div>
              </div>
              <p class="fw-bold mb-0 small"><%= event.title %></p>
              <p class="text-muted mb-0" style="font-size: 0.7rem"><%= event.user.profile&.username %></p>
              <p class="text-muted mb-1" style="font-size: 0.7rem"><%= event.address %></p>
              <p class="small mb-0"><%= pluralize(event.attendances.count, "presença", "presenças") %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

</div>

<%= render "shared/footer_nav" %>

<%# Modal de compartilhar %>
<div class="modal fade" id="shareModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 p-4">
      <div class="modal-body" data-controller="user-search">
        <h5 class="fw-bold mb-1">Compartilhar encontro</h5>
        <p class="text-muted small mb-3">Busque pelo nome ou @username da sua amiga.</p>
        <%= form_with url: shares_path, method: :post, data: { turbo: false } do |f| %>
          <%= hidden_field_tag :event_id, @event.id %>
          <%= hidden_field_tag :username, nil, data: { user_search_target: "username" } %>

          <input type="text"
                 class="form-control mb-1"
                 placeholder="Buscar por nome ou @username"
                 autocomplete="off"
                 data-user-search-target="input"
                 data-action="input->user-search#search">

          <div class="border rounded-3 mb-3 d-none" data-user-search-target="results"></div>

          <%= f.submit "Compartilhar", class: "btn btn-dark w-100" %>
        <% end %>
        <button class="btn btn-link text-muted small w-100 mt-1" data-bs-dismiss="modal">Cancelar</button>
      </div>
    </div>
  </div>
</div>

<%# Modal da criadora %>
<div class="modal fade" id="creatorModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content border-0 rounded-4">
      <div class="modal-body p-4">

        <%# Header do perfil %>
        <div class="d-flex align-items-center gap-3 mb-3">
          <div class="rounded-circle bg-secondary flex-shrink-0" style="width: 56px; height: 56px;"></div>
          <div>
            <p class="fw-bold mb-0"><%= @creator.profile&.name %></p>
            <p class="text-muted small mb-0">@<%= @creator.profile&.username %></p>
            <% if @creator.profile&.location.present? %>
              <p class="text-muted small mb-0"><i class="fa-solid fa-location-dot me-1"></i><%= @creator.profile.location %></p>
            <% end %>
          </div>
        </div>

        <%# Bio %>
        <% if @creator.profile&.description.present? %>
          <p class="small text-muted fst-italic mb-3">"<%= @creator.profile.description %>"</p>
        <% end %>

        <%# Avaliação média %>
        <% avg = @creator.average_rating %>
        <div class="d-flex align-items-center gap-2 mb-3">
          <% if avg %>
            <span style="color: #e74c3c; font-size: 1.1rem">
              <% avg.round.times do %>♥<% end %>
            </span>
            <span class="small text-muted"><%= avg %> · <%= @creator_reviews.count %> <%= @creator_reviews.count == 1 ? "avaliação" : "avaliações" %></span>
          <% else %>
            <span class="small text-muted">Sem avaliações ainda</span>
          <% end %>
        </div>

        <%# Avaliações com scroll %>
        <% if @creator_reviews.any? %>
          <p class="small fw-bold mb-2">O que disseram (<%= @creator_reviews.count %>):</p>
          <div style="max-height: 220px; overflow-y: auto">
            <% @creator_reviews.each do |review| %>
              <div class="bg-light rounded-3 p-2 mb-2">
                <div class="d-flex align-items-center justify-content-between mb-1">
                  <span class="small fw-bold"><%= review.reviewer.profile&.username %></span>
                  <span style="font-size: 0.8rem; color: #e74c3c"><% review.rating.times do %>♥<% end %></span>
                </div>
                <% if review.comment.present? %>
                  <p class="small fst-italic mb-1">"<%= review.comment %>"</p>
                <% end %>
                <p class="text-muted mb-0" style="font-size: 0.7rem">
                  <i class="fa-solid fa-calendar me-1"></i><%= review.event.title %>
                </p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted small">Sem avaliações ainda.</p>
        <% end %>

        <%# CTAs %>
        <div class="mt-3 d-flex gap-2">
          <%= link_to events_path(city: @creator.profile&.location), class: "btn btn-outline-dark btn-sm w-100" do %>
            Ver encontros em <%= @creator.profile&.location %>
          <% end %>
          <button class="btn btn-outline-secondary btn-sm w-100" data-bs-dismiss="modal">Fechar</button>
        </div>

      </div>
    </div>
  </div>
</div>
