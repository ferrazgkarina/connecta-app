<div class="container py-4 pb-5" style="max-width: 480px">

  <h1 class="fs-5 fw-bold mb-4">Conversas</h1>

  <% if @events.any? %>
    <div class="d-flex flex-column gap-2">
      <% @events.each do |event| %>
        <% last_msg = event.messages.order(:created_at).last %>
        <%= link_to event_path(event), class: "text-decoration-none text-dark" do %>
          <div class="border rounded-3 p-3 d-flex align-items-center gap-3">
            <%# Avatar placeholder %>
            <div class="rounded-circle bg-secondary flex-shrink-0" style="width: 44px; height: 44px;"></div>

            <div class="flex-grow-1 overflow-hidden">
              <div class="d-flex justify-content-between align-items-center">
                <p class="fw-bold small mb-0 text-truncate"><%= event.title %></p>
                <% if last_msg %>
                  <span class="text-muted flex-shrink-0 ms-2" style="font-size: 0.65rem">
                    <%= last_msg.created_at.strftime("%d/%m %H:%M") %>
                  </span>
                <% end %>
              </div>
              <% if last_msg %>
                <p class="text-muted small mb-0 text-truncate" style="font-size: 0.75rem">
                  <strong>@<%= last_msg.user.profile&.username || last_msg.user.email.split("@").first %>:</strong>
                  <%= last_msg.content %>
                </p>
              <% else %>
                <p class="text-muted small mb-0" style="font-size: 0.75rem">Nenhuma mensagem ainda</p>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <i class="fa-solid fa-message text-muted mb-3" style="font-size: 2.5rem"></i>
      <p class="text-muted">Você ainda não participa de nenhum encontro com chat.</p>
      <%= link_to "Explorar encontros", root_path, class: "btn btn-dark btn-sm" %>
    </div>
  <% end %>

</div>

<%= render "shared/footer_nav" %>
