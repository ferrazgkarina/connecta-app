<!DOCTYPE html>
<html>
  <head>
    <title>ConnectaApp</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if flash[:notice] && flash[:notice] != "registered" %>
      <div class="position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index: 9999; min-width: 300px">
        <div class="alert alert-dark alert-dismissible fade show rounded-3 shadow-sm text-center py-2" role="alert">
          <%= flash[:notice] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index: 9999; min-width: 300px">
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm text-center py-2" role="alert">
          <%= flash[:alert] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      </div>
    <% end %>
    <%= yield %>
  </body>
</html>
