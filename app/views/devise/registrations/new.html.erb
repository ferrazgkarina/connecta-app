<div class="container d-flex flex-column align-items-center justify-content-center min-vh-100">
  <div class="w-100" style="max-width: 360px">
    <div class="text-center mb-4">
      <h1 class="fs-4 fw-bold">Como você quer começar?</h1>
    </div>

    <button class="btn btn-outline-dark w-100 mb-4" disabled>Entrar com Google</button>

    <%= render "devise/shared/error_messages", resource: resource %>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div data-controller="email-check">
        <%= f.input :email,
                    label: false,
                    placeholder: "Email",
                    required: true,
                    autofocus: true,
                    input_html: {
                      autocomplete: "email",
                      class: "form-control mb-1",
                      data: {
                        email_check_target: "input",
                        action: "input->email-check#check"
                      }
                    } %>
        <p data-email-check-target="feedback" class="mb-2" style="font-size: 0.8rem"></p>
      </div>

      <%= f.input :password,
                  label: false,
                  placeholder: "Senha",
                  required: true,
                  hint: false,
                  input_html: { autocomplete: "new-password", class: "form-control mb-2" } %>
      <%= f.input :password_confirmation,
                  label: false,
                  placeholder: "Confirme sua senha",
                  required: true,
                  input_html: { autocomplete: "new-password", class: "form-control mb-3" } %>

      <%= f.button :submit, "Criar conta", class: "btn btn-outline-dark w-100" %>
    <% end %>
  </div>
</div>
